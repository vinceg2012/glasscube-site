{
  "name": "glasscube-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Static site for GlassCube AR",
  "scripts": {
    "seo:fix": "node scripts/seo-fix.mjs",
    "seo:check": "node scripts/seo-fix.mjs --check",
    "test": "node --test --experimental-test-coverage 'test/**/*.test.mjs'",
    "test:plain": "node --test 'test/**/*.test.mjs'",
    "ship": "node scripts/ship.mjs",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
